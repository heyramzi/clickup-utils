{
  "name": "@heyramzi/clickup-utils",
  "version": "1.0.0",
  "description": "Universal TypeScript types and services for ClickUp API integration.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyramzi/clickup-utils.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    },
    "./core/*": {
      "types": "./dist/core/*.d.ts",
      "import": "./dist/core/*.js"
    },
    "./api/*": {
      "types": "./dist/api/*.d.ts",
      "import": "./dist/api/*.js"
    },
    "./transformers/*": {
      "types": "./dist/transformers/*.d.ts",
      "import": "./dist/transformers/*.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "build:cli": "pnpm --filter @clickup-utils/cli run build",
    "build:all": "pnpm run build && pnpm run build:cli",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
